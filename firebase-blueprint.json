{
  "entities": {
    "Ingredient": {
      "title": "Ingredient",
      "description": "Analyzed ingredient information including efficacy, evidence, and timeframe.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID (usually the ingredient name in lowercase/slugified)" },
        "name": { "type": "string", "description": "Ingredient name (Japanese)" },
        "enName": { "type": "string", "description": "Ingredient name (English)" },
        "function": { "type": "string", "description": "Primary function/efficacy" },
        "evidence": { "type": "string", "description": "Scientific evidence or mechanism" },
        "timeframe": { "type": "string", "description": "Expected timeframe for results" },
        "lastAnalyzed": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "function"]
    },
    "Product": {
      "title": "Product",
      "description": "A skincare product (Serum or Ampoule)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["serum", "foundation", "performance"] },
        "price": { "type": "number" },
        "isPublished": { "type": "boolean" },
        "ingredients": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "type", "price"]
    },
    "UserSession": {
      "title": "User Session",
      "description": "A user's consultation session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "startTime": { "type": "number" },
        "lastActive": { "type": "number" },
        "status": { "type": "string" },
        "currentStep": { "type": "string" },
        "demographics": { "type": "object" }
      },
      "required": ["sessionId", "startTime"]
    },
    "LogEntry": {
      "title": "Log Entry",
      "description": "An event log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "timestamp": { "type": "number" },
        "type": { "type": "string" },
        "payload": { "type": "object" }
      },
      "required": ["id", "sessionId", "timestamp", "type"]
    },
    "MasterConfig": {
      "title": "Master Configuration",
      "description": "Dynamic configuration for consultation questions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string", "enum": ["skin_concerns", "ideal_goals", "lifestyle_factors", "dissatisfactions", "trouble_history", "concern_timings", "current_lacks", "usage_durations"] },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "order": { "type": "number" },
        "isActive": { "type": "boolean" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "category", "label"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile with role-based access control.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastLogin": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and permissions"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Skincare products"
    },
    "/sessions/{sessionId}": {
      "schema": "UserSession",
      "description": "User consultation sessions"
    },
    "/logs/{logId}": {
      "schema": "LogEntry",
      "description": "Event logs"
    },
    "/master_configs/{configId}": {
      "schema": "MasterConfig",
      "description": "Dynamic consultation question items"
    },
    "/ingredients/{ingredientId}": {
      "schema": "Ingredient",
      "description": "Analyzed ingredient data for reuse across products."
    }
  }
}
